<Window
    x:Class="ChatbotClient.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ChatbotClient.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ChatbotClient.ViewModels"
    Title="{Binding Title}"
    Width="525"
    Height="350"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox
            Grid.Row="0"
            Grid.RowSpan="4"
            Grid.Column="0"
            Width="200"
            ItemsSource="{Binding Sessions}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:TalkSession}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="0" Grid.Column="1">
            <ComboBox
                Width="200"
                HorizontalAlignment="Right"
                ItemsSource="{Binding AvailableModels}"
                SelectedItem="{Binding CurrentModel}" />
        </Border>

        <TextBox
            Grid.Row="1"
            Grid.Column="1"
            Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged, Delay=1000}" />

        <TextBlock
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding ResponseText}"
            TextWrapping="Wrap" />

        <Border
            Grid.Row="3"
            Grid.Column="1"
            Margin="0,10,0,0">
            <Button
                Width="200"
                Padding="5"
                HorizontalAlignment="Right"
                Command="{Binding SendRequestCommand}">
                <TextBlock Text="Send" />
            </Button>
        </Border>

    </Grid>

</Window>