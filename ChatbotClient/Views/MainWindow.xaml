<Window
    x:Class="ChatbotClient.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mdXaml="https://github.com/whistyun/MdXaml"
    xmlns:models="clr-namespace:ChatbotClient.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ChatbotClient.ViewModels"
    Title="{Binding Title}"
    Width="525"
    Height="600"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox
            Grid.Row="0"
            Grid.RowSpan="4"
            Grid.Column="0"
            Width="200"
            ItemsSource="{Binding Sessions}"
            SelectedItem="{Binding CurrentSession}">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <b:InvokeCommandAction Command="{Binding LoadSessionAsyncCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:TalkSession}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="0" Grid.Column="1">
            <ComboBox
                Width="200"
                HorizontalAlignment="Right"
                ItemsSource="{Binding AvailableModels}"
                SelectedItem="{Binding CurrentModel}" />
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="1">
            <ItemsControl ItemsSource="{Binding Talks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="10" CornerRadius="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="{Binding Role, StringFormat={}{0}:}" />
                                    <mdXaml:MarkdownScrollViewer
                                        Grid.Row="1"
                                        FontFamily="Yu Gothic UI"
                                        FontSize="16"
                                        Foreground="DimGray"
                                        Markdown="{Binding Content}"
                                        PreviewMouseWheel="Markdown_PreviewMouseWheel"
                                        VerticalScrollBarVisibility="Disabled">
                                        <mdXaml:MarkdownScrollViewer.MarkdownStyle>
                                            <Style TargetType="FlowDocument">
                                                <Style.Resources>

                                                    <Style TargetType="{x:Type Run}">
                                                        <Style.Triggers>
                                                            <Trigger Property="Tag" Value="CodeSpan">
                                                                <Setter Property="Background" Value="LightGray" />
                                                                <Setter Property="FontFamily" Value="Yu Gothic UI" />
                                                                <Setter Property="BaselineAlignment" Value="Center" />
                                                                <Setter Property="FontSize" Value="16" />
                                                                <Setter Property="Foreground" Value="Black" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>

                                                </Style.Resources>
                                            </Style>
                                        </mdXaml:MarkdownScrollViewer.MarkdownStyle>
                                    </mdXaml:MarkdownScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Height="100"
            Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged, Delay=1000}" />

        <Border
            Grid.Row="3"
            Grid.Column="1"
            Margin="0,10,0,0">
            <Button
                Width="200"
                Padding="5"
                HorizontalAlignment="Right"
                Command="{Binding SendRequestCommand}">
                <TextBlock Text="Send" />
            </Button>
        </Border>

    </Grid>

</Window>