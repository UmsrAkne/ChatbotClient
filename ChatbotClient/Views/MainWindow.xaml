<Window
    x:Class="ChatbotClient.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ChatbotClient.Behaviors"
    xmlns:controls="clr-namespace:ChatbotClient.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mdXaml="https://github.com/whistyun/MdXaml"
    xmlns:models="clr-namespace:ChatbotClient.Models"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ChatbotClient.ViewModels"
    Title="{Binding Title}"
    Width="1280"
    Height="768"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{StaticResource DarkBackgroundBrush}"
    mc:Ignorable="d">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
            <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
            <Setter Property="Background" Value="{StaticResource MiddleBackgroundBrush}" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition x:Name="EditorColumn">
                <ColumnDefinition.Style>
                    <Style x:Name="EditorColumnStyle" TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=SidebarToggle, Path=IsChecked}" Value="True">
                                <Setter Property="Width" Value="300" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>

            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:CustomButton
            Grid.Row="0"
            Grid.Column="0"
            Padding="5"
            ButtonCommand="{Binding AddSessionCommand}">

            <controls:CustomButton.ButtonContent>
                <TextBlock HorizontalAlignment="Center" Text="New Chat Session" />
            </controls:CustomButton.ButtonContent>
        </controls:CustomButton>

        <Border
            Grid.Row="1"
            Grid.RowSpan="3"
            Grid.Column="0"
            Margin="0,8,0,0"
            Background="{StaticResource MiddleBackgroundBrush}"
            CornerRadius="{StaticResource CommonCornerRadius}">

            <ListBox
                Width="200"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding Sessions}"
                SelectedItem="{Binding CurrentSession}">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding LoadSessionAsyncCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:TalkSession}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="{StaticResource CommonFontSize}"
                                Foreground="{StaticResource CommonForegroundBrush}"
                                Text="{Binding Title}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="0" Grid.Column="1">
            <ComboBox
                Width="200"
                HorizontalAlignment="Right"
                ItemsSource="{Binding AvailableModels}"
                SelectedItem="{Binding CurrentModel}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="Black" Text="{Binding}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="1">
            <ItemsControl ItemsSource="{Binding Talks}">
                <b:Interaction.Behaviors>
                    <behaviors:AutoScrollBehavior />
                </b:Interaction.Behaviors>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5,5">
                            <Grid.Resources>

                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource CommonForegroundBrush}" />
                                    <Setter Property="FontSize" Value="{StaticResource CommonFontSize}" />
                                </Style>
                            </Grid.Resources>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="0.5*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="5" CornerRadius="10">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource SpeechBubbleBackgroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Role}" Value="User">
                                                <Setter Property="Background" Value="{StaticResource MiddleBackgroundBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="{Binding Role, StringFormat={}{0}:}" />
                                    <mdXaml:MarkdownScrollViewer
                                        Grid.Row="1"
                                        FontFamily="Yu Gothic UI"
                                        FontSize="{StaticResource CommonFontSize}"
                                        Foreground="{StaticResource CommonForegroundBrush}"
                                        Markdown="{Binding Content}"
                                        PreviewMouseWheel="Markdown_PreviewMouseWheel"
                                        VerticalScrollBarVisibility="Disabled">
                                        <mdXaml:MarkdownScrollViewer.MarkdownStyle>
                                            <Style TargetType="FlowDocument">
                                                <Style.Resources>

                                                    <Style TargetType="{x:Type Run}">
                                                        <Style.Triggers>
                                                            <Trigger Property="Tag" Value="CodeSpan">
                                                                <Setter Property="Background" Value="LightGray" />
                                                                <Setter Property="FontFamily" Value="Yu Gothic UI" />
                                                                <Setter Property="BaselineAlignment" Value="Center" />
                                                                <Setter Property="FontSize" Value="16" />
                                                                <Setter Property="Foreground" Value="Black" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>

                                                </Style.Resources>
                                            </Style>
                                        </mdXaml:MarkdownScrollViewer.MarkdownStyle>
                                    </mdXaml:MarkdownScrollViewer>

                                    <StackPanel
                                        Grid.Row="2"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding Timestamp, StringFormat=yyyy/mm/dd HH:MM}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Grid.Column="1">

            <StackPanel>
                <Border
                    Margin="4"
                    Background="{StaticResource MiddleBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CommonCornerRadius}">
                    <TextBox
                        x:Name="PromptInputTextBox"
                        Height="100"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged, Delay=1000}">
                        <TextBox.InputBindings>
                            <KeyBinding
                                Key="Enter"
                                Command="{Binding SendRequestCommand}"
                                CommandParameter="{Binding ElementName=PromptInputTextBox, Path=Text}"
                                Modifiers="Control" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>

                <DockPanel Margin="8,4">
                    <TextBlock Text="Context Length: " />
                    <TextBlock
                        Width="30"
                        FontWeight="Bold"
                        Text="{Binding MessageLimit}"
                        TextAlignment="Right" />

                    <Slider
                        Margin="10,0"
                        IsSnapToTickEnabled="True"
                        Maximum="50"
                        Minimum="0"
                        TickFrequency="1"
                        Value="{Binding MessageLimit}" />
                </DockPanel>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="3"
            Grid.Column="1"
            Margin="0,10,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <!--  -->
                <!-- <Button -->
                <!-- Width="200" -->
                <!-- Padding="5" -->
                <!-- HorizontalAlignment="Right" -->
                <!-- Command="{Binding AddDummyTalkCommand}"> -->
                <!--     <TextBlock Foreground="Black" Text="Add Dummy" /> -->
                <!-- </Button> -->
                <!--  -->

                <controls:CustomButton
                    Width="200"
                    Padding="5"
                    ButtonCommand="{Binding SendRequestCommand}">
                    <controls:CustomButton.ButtonContent>
                        <TextBlock HorizontalAlignment="Center" Text="Send (Ctrl + Enter)" />
                    </controls:CustomButton.ButtonContent>
                </controls:CustomButton>
            </StackPanel>
        </Border>

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Grid.Column="2"
            Visibility="{Binding ElementName=SidebarToggle, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>


                <DockPanel Grid.Row="0">
                    <TextBlock Margin="0,0,0,5" Text="System Prompt Here..." />

                    <controls:CustomButton
                        Width="40"
                        Height="{StaticResource ButtonHeight}"
                        Margin="5,0"
                        HorizontalAlignment="Right"
                        ButtonCommand="{Binding BrowseHistoryCommand}"
                        ButtonCommandParameter="1"
                        DockPanel.Dock="Right">
                        <controls:CustomButton.ButtonContent>
                            <TextBlock FontWeight="Bold" Text="→" />
                        </controls:CustomButton.ButtonContent>
                    </controls:CustomButton>

                    <controls:CustomButton
                        Width="40"
                        Height="{StaticResource ButtonHeight}"
                        HorizontalAlignment="Right"
                        ButtonCommand="{Binding BrowseHistoryCommand}"
                        ButtonCommandParameter="-1"
                        DockPanel.Dock="Right">
                        <controls:CustomButton.ButtonContent>
                            <TextBlock FontWeight="Bold" Text="←" />
                        </controls:CustomButton.ButtonContent>
                    </controls:CustomButton>
                </DockPanel>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource MiddleBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CommonCornerRadius}">

                    <TextBox
                        AcceptsReturn="True"
                        Text="{Binding CurrentSystemPrompt.PromptText, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </Border>

                <DockPanel Grid.Row="2" Margin="0,15,0,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        DockPanel.Dock="Top"
                        Text="Attached files Here..." />
                    <Border
                        Height="150"
                        AllowDrop="True"
                        Background="{StaticResource MiddleBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CommonCornerRadius}">

                        <ListBox
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding AttachedFiles}"
                            SelectionMode="Extended">
                            <b:Interaction.Behaviors>
                                <behaviors:DropFilesBehavior />
                                <behaviors:DeleteListItemBehavior />
                            </b:Interaction.Behaviors>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="{StaticResource CommonFontSize}"
                                            Foreground="{StaticResource CommonForegroundBrush}"
                                            Text="📄 " />
                                        <TextBlock
                                            FontSize="{StaticResource CommonFontSize}"
                                            Foreground="{StaticResource CommonForegroundBrush}"
                                            Text="{Binding FileName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>

            </Grid>
        </Border>

        <Border
            Grid.Row="0"
            Grid.RowSpan="4"
            Grid.Column="3"
            Width="40">
            <StackPanel>
                <ToggleButton
                    x:Name="SidebarToggle"
                    Height="35"
                    Margin="4,0,0,0"
                    IsChecked="True"
                    ToolTip="Edit System Prompt">
                    <ToggleButton.Content>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Foreground="Black"
                            Text="&gt;_" />
                    </ToggleButton.Content>
                </ToggleButton>
            </StackPanel>
        </Border>

    </Grid>

</Window>